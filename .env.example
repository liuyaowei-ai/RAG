# OpenAI 配置（使用 OpenAI 时必填）
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Ollama 配置（使用本地模型时生效）
OLLAMA_MODEL=qwen2.5:7b

# 公共配置
LLM_PROVIDER=openai
CHROMA_COLLECTION=medical_qa
EMBEDDING_MODEL_NAME=shibing624/text2vec-base-chinese
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K=4
